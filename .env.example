GEMINI_API_KEY=YOUR_GEMINI_KEY
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Realtime Collaboration (Optional: defaults to public signaling servers)
NEXT_PUBLIC_SIGNALING_SERVER=wss://your-signaling-server.com

# Google Drive Sync (Optional: enables auto-sync of diagrams to personal Google Drive)
# Create an OAuth 2.0 Web Client ID at https://console.cloud.google.com/
# Enable the Google Drive API and add your app origin to Authorized JavaScript origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
